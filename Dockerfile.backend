# LeKai 后端 Dockerfile
FROM python:3.12-slim

WORKDIR /app
RUN apt-get update -qq && apt-get install -y -qq curl && rm -rf /var/lib/apt/lists/*

# 安装依赖
COPY scripts/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 复制后端代码
COPY backend/ ./backend/
COPY scripts/ingest_knowledge.py ./scripts/

# 复制知识库（如存在）
COPY knowledge-base/ ./knowledge-base/

# 创建非 root 用户并设置目录权限
RUN mkdir -p /app/data /app/chroma_db /app/.cache /app/knowledge-base \
    && useradd -m -u 10001 lekai \
    && chown -R lekai:lekai /app

USER lekai

# 预下载 Embedding 模型（失败不阻塞构建，以 lekai 身份运行确保文件权限正确）
RUN python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('BAAI/bge-small-zh-v1.5', cache_folder='/app/.cache/models')" 2>/dev/null || echo "模型下载跳过（构建时网络不可用，首次运行时会自动下载）"

ENV DEEPSEEK_API_KEY=""
ENV DEEPSEEK_BASE_URL="https://api.deepseek.com"

EXPOSE 8000

CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000", "--proxy-headers"]
