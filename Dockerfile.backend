# LeKai 后端 Dockerfile
FROM python:3.12-slim

WORKDIR /app

# 安装依赖
COPY scripts/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt

# 复制后端代码
COPY backend/ ./backend/
COPY scripts/ingest_knowledge.py ./scripts/

# 复制知识库（如存在）
COPY knowledge-base/ ./knowledge-base/

# 预下载 Embedding 模型（可选，加速启动）
RUN python -c "from sentence_transformers import SentenceTransformer; SentenceTransformer('BAAI/bge-small-zh-v1.5', cache_folder='/app/.cache/models')"

ENV DEEPSEEK_API_KEY=""
ENV DEEPSEEK_BASE_URL="https://api.deepseek.com"

EXPOSE 8000

CMD ["uvicorn", "backend.main:app", "--host", "0.0.0.0", "--port", "8000", "--proxy-headers"]
