# LeKai教案知识库 - 环境变量配置

# DeepSeek API（用于教案生成）
DEEPSEEK_API_KEY=your_deepseek_api_key_here
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-v4-pro
DEEPSEEK_FAST_MODEL=deepseek-v4-flash
DEEPSEEK_MAX_TOKENS=8192
# Leave blank for faster interactive generation. Set to enabled/high for deeper reasoning.
DEEPSEEK_THINKING=disabled
DEEPSEEK_REASONING_EFFORT=

# 验收模式，仅交付验收时临时开启。正式生产必须保持 0。
LEKAI_ACCEPTANCE_MODE=0

# DEE 已内嵌到 LeKai 证据层：入库时保留 page_num/bbox/source_hash/page_image_url 等字段。
# 不需要单独配置 DEE 服务地址。

# 扫描 PDF OCR 入库
PDF_UPLOAD_MAX_MB=1024
PDF_OCR_MAX_PAGES=80
PDF_OCR_DPI_SCALE=2.0
PDF_OCR_LANG=chi_sim+eng
